# Polymarket Bot Configuration

# ==============================================================================
# REQUIRED API CREDENTIALS
# These are essential for the bot to interact with the Polymarket CLOB.
# You can obtain these from your Polymarket account settings.
# ==============================================================================
PRIVATE_KEY= # Your wallet's private key (hex string). NEVER share this!
API_KEY=     # Your Polymarket API Key
API_SECRET=  # Your Polymarket API Secret
API_PASSPHRASE= # Your Polymarket API Passphrase

# ==============================================================================
# OPTIONAL - PROXY CONFIGURATION
# Use these if you need to route your traffic through a proxy.
# ==============================================================================
# PROXY_URL=http://user:password@host:port # Example: http://user:pass@1.2.3.4:8080
# If you have a list of proxies to rotate through, provide them comma-separated:
# PROXIES_LIST=http://user1:pass1@host1:port1,http://user2:pass2@host2:port2
# MANUAL_PROXY= # Set a specific proxy address if USE_PROXY_WALLET is true and you have a proxy wallet address.

# ==============================================================================
# OPTIONAL - BOT BEHAVIOR SETTINGS
# Adjust these to control the bot's trading strategy and performance.
# ==============================================================================
RPC_URL="https://1rpc.io/matic" # Polygon RPC endpoint. Default is usually fine.
USE_PROXY_WALLET="0" # Set to "1" if you are using a Polymarket proxy wallet (e.g., Magic Link login). Otherwise, "0" for EOA.
TRADE_AMOUNT_USDC="5.0" # Amount of USDC to trade per opportunity. (e.g., "5.0" for 5 USDC)
POLL_INTERVAL_SECONDS="15" # How often the bot checks for new opportunities (in seconds).
FOCUS_CATEGORIES= # Comma-separated list of categories to focus on (e.g., "Crypto,Politics,Sports"). Leave empty for all.

# ==============================================================================
# DO NOT MODIFY BELOW THIS LINE
# ==============================================================================
